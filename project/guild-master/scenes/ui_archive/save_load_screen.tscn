[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/ui/save_load_screen.gd" id="1_screen"]
[ext_resource type="FontFile" path="res://assets/fonts/eczar/Eczar-Bold.ttf" id="2_font"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.05, 0.05, 0.05, 0.95)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_dialog"]
bg_color = Color(0.1, 0.1, 0.1, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
border_color = Color(0.3, 0.3, 0.3, 1)
shadow_color = Color(0, 0, 0, 0.6)
shadow_size = 20

[node name="SaveLoadScreen" type="CanvasLayer"]
layer = 1300
script = ExtResource("1_screen")

[node name="Panel" type="Panel" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="HBoxContainer" type="HBoxContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 50.0
offset_top = 50.0
offset_right = -50.0
offset_bottom = -50.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 50

[node name="LeftPanel" type="VBoxContainer" parent="Panel/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 2.0

[node name="Title" type="Label" parent="Panel/HBoxContainer/LeftPanel"]
unique_name_in_owner = true
layout_mode = 2
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 48
text = "UI_SAVE"

[node name="ScrollContainer" type="ScrollContainer" parent="Panel/HBoxContainer/LeftPanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="SlotGrid" type="GridContainer" parent="Panel/HBoxContainer/LeftPanel/ScrollContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 20
theme_override_constants/v_separation = 20
columns = 3

[node name="RightPanel" type="VBoxContainer" parent="Panel/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="DetailsTitle" type="Label" parent="Panel/HBoxContainer/RightPanel"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "UI_DETAILS"
horizontal_alignment = 1

[node name="DetailsText" type="RichTextLabel" parent="Panel/HBoxContainer/RightPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
text = "[center]Select a slot...[/center]"

[node name="DeleteButton" type="Button" parent="Panel/HBoxContainer/RightPanel"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_colors/font_color = Color(0.8, 0.2, 0.2, 1)
text = "UI_DELETE"

[node name="BackButton" type="Button" parent="Panel/HBoxContainer/RightPanel"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
text = "UI_BACK"

[node name="ContextMenu" type="PanelContainer" parent="."]
unique_name_in_owner = true
visible = false
offset_right = 200.0
offset_bottom = 100.0

[node name="VBox" type="VBoxContainer" parent="ContextMenu"]
layout_mode = 2

[node name="OverwriteButton" type="Button" parent="ContextMenu/VBox"]
layout_mode = 2
text = "UI_OVERWRITE"

[node name="LoadButton" type="Button" parent="ContextMenu/VBox"]
layout_mode = 2
text = "UI_LOAD"

[node name="CustomConfirmDialog" type="Control" parent="."]
unique_name_in_owner = true
visible = false
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Dimmer" type="ColorRect" parent="CustomConfirmDialog"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)

[node name="DialogPanel" type="PanelContainer" parent="CustomConfirmDialog"]
custom_minimum_size = Vector2(500, 250)
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -250.0
offset_top = -125.0
offset_right = 250.0
offset_bottom = 125.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_dialog")

[node name="VBox" type="VBoxContainer" parent="CustomConfirmDialog/DialogPanel"]
layout_mode = 2
theme_override_constants/separation = 30
alignment = 1

[node name="ConfirmMessage" type="Label" parent="CustomConfirmDialog/DialogPanel/VBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(400, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Confirmation Message?"
horizontal_alignment = 1
autowrap_mode = 2

[node name="HBox" type="HBoxContainer" parent="CustomConfirmDialog/DialogPanel/VBox"]
layout_mode = 2
theme_override_constants/separation = 50
alignment = 1

[node name="ConfirmOK" type="Button" parent="CustomConfirmDialog/DialogPanel/VBox/HBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
text = "OK"

[node name="ConfirmCancel" type="Button" parent="CustomConfirmDialog/DialogPanel/VBox/HBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
text = "CANCEL"

[connection signal="pressed" from="Panel/HBoxContainer/RightPanel/DeleteButton" to="." method="_on_delete_pressed"]
[connection signal="pressed" from="Panel/HBoxContainer/RightPanel/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="ContextMenu/VBox/OverwriteButton" to="." method="_on_overwrite_pressed"]
[connection signal="pressed" from="ContextMenu/VBox/LoadButton" to="." method="_on_load_pressed"]
[connection signal="pressed" from="CustomConfirmDialog/DialogPanel/VBox/HBox/ConfirmOK" to="." method="_on_confirmed"]
[connection signal="pressed" from="CustomConfirmDialog/DialogPanel/VBox/HBox/ConfirmCancel" to="." method="_on_confirm_cancel_pressed"]
